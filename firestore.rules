rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Phase 3 Primitives
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }

    // Validation blueprints
    function isValidUserProfile(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 200 &&
             (data.get('displayName', '') is string) &&
             (data.get('photoURL', '') is string) &&
             (data.get('language', '') is string) &&
             (data.get('createdAt', 0) is number) &&
             (data.get('updatedAt', 0) is number);
    }

    function isValidBookmark(data) {
      return data.keys().hasAll(['id', 'title', 'cover', 'type', 'addedAt', 'userId']) &&
             data.userId == request.auth.uid &&
             data.id is string && data.id.size() <= 128 &&
             data.title is string && data.title.size() <= 200 &&
             data.cover is string && data.cover.size() <= 500 &&
             data.type is string && data.type.size() <= 50 &&
             data.addedAt is number &&
             (data.get('totalChapters', 0) is number) &&
             (data.get('hasNewChapters', false) is bool);
    }

    function isValidReadingHistory(data) {
      return data.keys().hasAll(['mangaId', 'chapterId', 'source', 'chapterNumber', 'page', 'timestamp', 'title', 'cover', 'userId']) &&
             data.userId == request.auth.uid &&
             data.mangaId is string && data.mangaId.size() <= 128 &&
             data.chapterId is string && data.chapterId.size() <= 128 &&
             data.source is string && data.source.size() <= 128 &&
             data.chapterNumber is string && data.chapterNumber.size() <= 50 &&
             data.page is number &&
             data.timestamp is number &&
             data.title is string && data.title.size() <= 200 &&
             data.cover is string && data.cover.size() <= 500 &&
             (data.get('provider', '') is string);
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && isValidId(userId) && request.auth.uid == userId && isValidUserProfile(incoming());
      allow update: if isSignedIn() && isValidId(userId) && request.auth.uid == userId && isValidUserProfile(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'language', 'updatedAt']);
      allow delete: if isSignedIn() && request.auth.uid == userId;

      match /bookmarks/{mangaId} {
        allow get: if isSignedIn() && request.auth.uid == userId;
        allow list: if isSignedIn() && request.auth.uid == userId;
        allow create: if isSignedIn() && isValidId(userId) && isValidId(mangaId) && request.auth.uid == userId && isValidBookmark(incoming());
        allow update: if isSignedIn() && isValidId(userId) && isValidId(mangaId) && request.auth.uid == userId && isValidBookmark(incoming());
        allow delete: if isSignedIn() && request.auth.uid == userId;
      }

      match /history/{mangaId} {
        allow get: if isSignedIn() && request.auth.uid == userId;
        allow list: if isSignedIn() && request.auth.uid == userId;
        allow create: if isSignedIn() && isValidId(userId) && isValidId(mangaId) && request.auth.uid == userId && isValidReadingHistory(incoming());
        allow update: if isSignedIn() && isValidId(userId) && isValidId(mangaId) && request.auth.uid == userId && isValidReadingHistory(incoming());
        allow delete: if isSignedIn() && request.auth.uid == userId;
      }
    }
  }
}
