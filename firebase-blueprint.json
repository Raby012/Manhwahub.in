{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "language": { "type": "string" },
        "createdAt": { "type": "integer" },
        "updatedAt": { "type": "integer" }
      },
      "required": ["uid", "email"]
    },
    "Bookmark": {
      "title": "Bookmark",
      "description": "A user's bookmarked manhwa",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "cover": { "type": "string" },
        "type": { "type": "string" },
        "addedAt": { "type": "integer" },
        "totalChapters": { "type": "integer" },
        "hasNewChapters": { "type": "boolean" },
        "userId": { "type": "string" }
      },
      "required": ["id", "title", "cover", "type", "addedAt", "userId"]
    },
    "ReadingHistory": {
      "title": "ReadingHistory",
      "description": "A user's reading history for a manhwa",
      "type": "object",
      "properties": {
        "mangaId": { "type": "string" },
        "chapterId": { "type": "string" },
        "source": { "type": "string" },
        "provider": { "type": "string" },
        "chapterNumber": { "type": "string" },
        "page": { "type": "integer" },
        "timestamp": { "type": "integer" },
        "title": { "type": "string" },
        "cover": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["mangaId", "chapterId", "source", "chapterNumber", "page", "timestamp", "title", "cover", "userId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles"
    },
    "/users/{userId}/bookmarks/{mangaId}": {
      "schema": "Bookmark",
      "description": "Bookmarks for a user"
    },
    "/users/{userId}/history/{mangaId}": {
      "schema": "ReadingHistory",
      "description": "Reading history for a user"
    }
  }
}
